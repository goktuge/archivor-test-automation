BASE_URL=
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
LOGIN_PATH=/auth/login

# Optional: tag-based test execution
# TEST_TAG=@smoke
# TEST_EXCLUDE=@skip

# Archivor GraphQL API (for api tests)
# Token from app Network tab - use raw token, NO "Bearer " prefix
# ARCHIVOR_TOKEN=eyJhbGciOiJSUzI1NiJ9...

# Gmail OAuth (for user factory - signup activation emails)
# See docs/gmail-oauth-setup.md
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# InfluxDB (optional - for metrics monitoring)
# INFLUX_URL=https://us-central1-1.gcp.cloud2.influxdata.com
# INFLUX_TOKEN=your-api-token
# INFLUX_ORG=your-org
# INFLUX_BUCKET=playwright_metrics
